{
  "name": "tunli-server",
  "version": "0.1.0",
  "description": "Self-hosted reverse tunnel server — exposes local services to the public internet via unique subdomains",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/tunlijs/tunli-server.git"
  },
  "engines": {
    "node": ">=22.0"
  },
  "files": [
    "dist/",
    "example/",
    "README.md",
    "LICENSE",
    "ROADMAP.md"
  ],
  "type": "module",
  "bin": {
    "tunli-server": "./dist/cli.js"
  },
  "scripts": {
    "prepublishOnly": "npm test",
    "clean": "rm -rf dist",
    "start": "node dist/daemon-main.js",
    "dev": "tsx src/daemon-main.ts",
    "build": "npm run clean && tsc",
    "build:sea": "npm run build && scripts/build-sea.sh",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-exclude='test/**'",
    "test:coverage:c8": "npm run build && npx c8 node --test",
    "test:coverage:lcov": "npm run build && npx c8 --src src node --enable-source-maps --test"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.4",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  },
  "imports": {
    "#*": "./dist/*.js"
  },
  "dependencies": {
    "@pfeiferio/custom-base": "^1.0.1",
    "@pfeiferio/express-middlewares": "^1.11.0",
    "@pfeiferio/konfi": "^1.0.0",
    "@pfeiferio/object-utils": "^1.1.1",
    "@pfeiferio/string-interpolate": "^1.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "redis": "^5.11.0",
    "request-drain": "^1.2.0",
    "socket.io": "^4.8.3"
  }
}
